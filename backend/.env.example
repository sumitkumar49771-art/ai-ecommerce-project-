PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai_ecommerce
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRE=7d

# Extra secret required to log in to any admin account, on top of the
# email/password. It is never typed anywhere — it must already be sitting
# in that browser's localStorage (set once via the browser console by the
# owner). Any other laptop/phone/browser can never produce it, so admin
# login fails there even with the correct email + password. Pick any long
# random string.
ADMIN_DEVICE_KEY=

# Optional: only needed if you want to use real OpenAI-powered chatbot
# instead of the built-in rule-based AI assistant.
# OPENAI_API_KEY=your_openai_api_key_here

# REQUIRED for real online payments + real refunds:
# https://dashboard.razorpay.com/signup -> Settings -> API Keys -> Generate Test Key
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# See backend/.env for setup instructions (Gmail App Password).
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
FRONTEND_URL=http://127.0.0.1:5501/frontend
